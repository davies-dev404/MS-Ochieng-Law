{
  "rewrites": [
    {
      "source": "/api/gemini/(.*)",
      "destination": "https://generativelanguage.googleapis.com/$1"
    },
    {
      "source": "/api/serper/(.*)",
      "destination": "https://google.serper.dev/$1"
    },
    {
      "source": "/api/openai/(.*)",
      "destination": "https://api.openai.com/$1"
    },
    {
      "source": "/api/groq/(.*)",
      "destination": "https://api.groq.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
